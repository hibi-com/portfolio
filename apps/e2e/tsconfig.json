{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["@portfolio/tsconfig/base.json"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"]
    },
    "types": ["@cloudflare/workers-types", "@types/bun", "node"]
  },
  "include": ["src/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist", ".wrangler"]
}
